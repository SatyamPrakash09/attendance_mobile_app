{
  "expo": {
    "name": "Attendance",
    "slug": "attendance",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app_icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "config": {}
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/app_icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.satyam_prakash_09.AttendanceMarker",
      "config": {},
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/app_icon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/app_icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F0E17",
          "dark": {
            "backgroundColor": "#0F0E17"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/app_icon.png",
          "color": "#7C3AED",
          "defaultChannel": "attendance"
        }
      ],
      "expo-background-task"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "57ed8b82-e4e7-44cd-9a4b-5b41ca047478"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/57ed8b82-e4e7-44cd-9a4b-5b41ca047478"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
